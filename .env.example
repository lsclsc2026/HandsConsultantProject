# OpenAI 兼容接口配置（可接入 DeepSeek / Qwen / OpenAI 等）
LLM_API_KEY=
LLM_BASE_URL=
LLM_TEXT_MODEL=
LLM_VISION_MODEL=
LLM_SUMMARY_MODEL=

# 可选：单独的重写模型和反思模型
LLM_REWRITE_MODEL=
LLM_REFLECT_MODEL=

# 可选：重排序模型开关
# 1=启用；0=禁用（禁用后使用词法重排，不访问 HF）
RERANKER_ENABLED=1

# 1=仅加载本地缓存，不联网下载；0=允许联网下载
RERANKER_LOCAL_ONLY=1

# 可选：重排序模型名
RERANKER_MODEL=BAAI/bge-reranker-v2-m3